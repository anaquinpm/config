[user]
    name = My Name
    email = myMail@gmail.com
[core]
    editor = vim
[diff]
    tool = vimdiff
[merge]
    tool = vimdiff
    conflictstyle = diff3
[help]
    autocorrect = 20
[alias]
    st = status -sb
    cm = commit -m
    cma = commit -am
    cmne = commit --amend --no-edit
    dv = difftool -t vimdiff -y
    se = !git rev-list --all | xargs git grep -F
    ll = log --oneline --graph --decorate --all
    los = log --oneline --graph --decorate --all --stat
    las = log --pretty='%C(bold blue)%h%C(reset) %C(yellow)%d%C(reset) - %C(green)%ce%C(reset), %C(cyan)%ar%C(reset) : %s' --graph --stat --decorate=short --all --color=always
    last = log -1 HEAD --stat
    pob = push -u origin HEAD
    mq = merge --squash
    gcount = rev-list --count main..HEAD
    ri = "!f() { \
        local branch=${1:-main}; \
        local count=$(git rev-list --count ${branch}..HEAD); \
        if [ $count -gt 0 ]; then \
            git rebase -i HEAD~$count; \
        else \
            echo \"No hay commits nuevos respecto a $branch\"; \
        fi \
    }; f"
[init]
    defaultBranch = main
